# Server-side-only secrets for local admin/diagnostic scripts
# (e.g. verify_shared_device_baselines.js). NEVER commit the real
# .env.server file, and NEVER reference these values from Flutter/web
# client code -- only from Node scripts run on a trusted machine.
#
# Copy this file to .env.server, fill in real values, then load it
# before running a script, e.g.:
#   PowerShell:  Get-Content .env.server | ForEach-Object { if ($_ -match '^([^#=]+)=(.*)$') { Set-Item "env:$($matches[1])" $matches[2] } }
#   bash:        export $(grep -v '^#' .env.server | xargs)

SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
