# Copy to functions/.env (already git-ignored) and fill in real values.
# Never commit functions/.env.

# Existing
MAPS_SERVER_KEY=YOUR_GOOGLE_MAPS_SERVER_KEY

# Supabase server-side access (service-role key -- full DB access, never
# expose to mobile/web client code, only used here in Cloud Functions)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Shared secret the Supabase Database Webhook must send back to
# syncDeviceAssignment / testDeviceSync in the "x-webhook-secret" header.
# Configure the matching header value in Supabase Dashboard -> Database ->
# Webhooks -> (this webhook) -> HTTP Headers.
SUPABASE_WEBHOOK_SECRET=GENERATE_A_LONG_RANDOM_VALUE

# Shared secret required (via "x-admin-secret" header) to call admin/debug
# HTTP endpoints such as clearAnxietyRateLimits.
ADMIN_TOOLS_SECRET=GENERATE_A_LONG_RANDOM_VALUE
